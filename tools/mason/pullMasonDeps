#!/usr/bin/env bash


MASON_DIR=$(cd $(dirname ${BASH_SOURCE[0]}) ; pwd)
DEPS_FILE="$MASON_DIR/ThirdParty/masonDeps.txt"

# if masonDeps does not exist, skip
if [ ! -f "$DEPS_FILE" ]; then
  echo "No masonDeps.txt found, skipping dependency download"
  exit 0
fi

while IFS= read -r line; do
  # skip empty lines and comments
  [[ -z "$line" || "$line" == \#* ]] && continue

  # FORMAT: FILENAME@URL@SHA
  filename=$(echo "$line" | cut -d '@' -f 1)
  url=$(echo "$line" | cut -d '@' -f 2)
  sha=$(echo "$line" | cut -d '@' -f 3)

  rm -f $MASON_DIR/ThirdParty/$filename
  if command -v curl > /dev/null; then
    # use curl if available
    curl -sSfL "$url" -o "$MASON_DIR/ThirdParty/$filename"
  else
    # fall back to python
    python3 -c "import urllib.request; urllib.request.urlretrieve('$url', '$MASON_DIR/ThirdParty/$filename')"
  fi
  if [ ! -f "$MASON_DIR/ThirdParty/$filename" ]; then
    echo "Failed to download $filename from $url"
    exit 1
  fi

  # verify the sha256
  (cd $MASON_DIR/ThirdParty/ && echo "$sha  $filename" | shasum -a 256 -c -)
  if [ $? -ne 0 ]; then
    echo "SHA256 verification failed for $filename"
    exit 1
  fi

  echo "Downloaded $filename"
done < "$DEPS_FILE"

echo "this file indicates a successful run">$MASON_DIR/ThirdParty/downloaded.txt

echo "Patching includes to be relative..."
# because we have shoved these dependencies into a submodule, we need to fix the
# includes to be relative.
for dep in $(ls $MASON_DIR/ThirdParty/*.chpl); do
  modName=$(basename $dep .chpl)
  for other in $(ls $MASON_DIR/ThirdParty/*.chpl); do
  otherName=$(basename $other .chpl)
    if grep -q "import $modName" $other; then
      if [ "$otherName" != "$modName" ]; then
        sed "s/import $modName/import super.$modName/g" $other > $other.tmp && mv $other.tmp $other
      else
        # relative imports to ourselves need to use the parent module name
        sed "s/import $modName/import ThirdParty.${modName}/g" $other > $other.tmp && mv $other.tmp $other
      fi
    fi
  done
done

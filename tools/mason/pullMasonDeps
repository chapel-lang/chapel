#!/usr/bin/env bash


MASON_DIR=$(cd $(dirname ${BASH_SOURCE[0]}) ; pwd)
DEPS_FILE="$MASON_DIR/ThirdParty/masonDeps.txt"

# if masonDeps does not exist, skip
if [ ! -f "$DEPS_FILE" ]; then
  echo "No masonDeps.txt found, skipping dependency download"
  exit 0
fi

while IFS= read -r line; do
  # skip empty lines and comments
  [[ -z "$line" || "$line" == \#* ]] && continue

  filename="${line%%@*}"
  url="${line#*@}"

  rm -f $MASON_DIR/ThirdParty/$filename
  if command -v curl > /dev/null; then
    # use curl if available
    curl -sSfL "$url" -o "$MASON_DIR/ThirdParty/$filename"
  else
    # fall back to python
    python3 -c "import urllib.request; urllib.request.urlretrieve('$url', '$MASON_DIR/ThirdParty/$filename')"
  fi
  if [ ! -f "$MASON_DIR/ThirdParty/$filename" ]; then
    echo "Failed to download $filename from $url"
    exit 1
  fi
  echo "Downloaded $filename"
done < "$DEPS_FILE"



#!/usr/bin/env bash

OUTFILE=$2

sed -E 's/[0-9]+([.][0-9]+)? seconds/n seconds/' $OUTFILE > $OUTFILE.tmp
mv $OUTFILE.tmp $OUTFILE

sed -e '/initial commit$/d' -e '/insertions/d' -e '/create mode/d' $OUTFILE > $OUTFILE.tmp
mv $OUTFILE.tmp $OUTFILE

sed -e "/PKG_CONFIG_PATH=/d" $OUTFILE > $OUTFILE.tmp
mv $OUTFILE.tmp $OUTFILE
